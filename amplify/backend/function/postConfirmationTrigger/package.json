    "function": {
      "postConfirmationTrigger": {
        "build": true,
        "providerPlugin": "awscloudformation",
        "service": "Lambda"
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1035.0",
    "@aws-sdk/util-dynamodb": "^3.996.2"
  }
