        "TypeName": "Query",
        "FieldName": "getMyFollowers",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyFollowers.js"
        }
      }
    },
    "GetMyFollowingsResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Query",
        "FieldName": "getMyFollowings",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyFollowings.js"
        }
      }
    },
    "GetMyPendingRequestsResolver": {
      "Type": "AWS::AppSync::Resolver",
