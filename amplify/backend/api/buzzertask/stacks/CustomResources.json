{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Custom resources for the Buzzer social graph API.",
  "Parameters": {
    "AppSyncApiId": {
      "Type": "String"
    },
    "AppSyncApiName": {
      "Type": "String",
      "Default": "buzzertask"
    },
    "env": {
      "Type": "String",
      "Default": "NONE"
    },
    "S3DeploymentBucket": {
      "Type": "String"
    },
    "S3DeploymentRootKey": {
      "Type": "String"
    }
  },
  "Resources": {
    "BuzzerNoneDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerNoneDS",
        "Type": "NONE"
      }
    },
    "FollowsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {
          "Fn::Sub": "BuzzerFollows-${AppSyncApiId}-${env}"
        },
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "requesterId", "AttributeType": "S" },
          { "AttributeName": "targetId", "AttributeType": "S" },
          { "AttributeName": "status", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "requesterId", "KeyType": "HASH" },
          { "AttributeName": "targetId", "KeyType": "RANGE" }
        ],
        "GlobalSecondaryIndexes": [
          {
            "IndexName": "byTarget",
            "KeySchema": [
              { "AttributeName": "targetId", "KeyType": "HASH" },
              { "AttributeName": "status", "KeyType": "RANGE" }
            ],
            "Projection": { "ProjectionType": "ALL" }
          },
          {
            "IndexName": "byRequester",
            "KeySchema": [
              { "AttributeName": "requesterId", "KeyType": "HASH" },
              { "AttributeName": "status", "KeyType": "RANGE" }
            ],
            "Projection": { "ProjectionType": "ALL" }
          }
        ]
      }
    },
    "NotificationsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {
          "Fn::Sub": "BuzzerNotifications-${AppSyncApiId}-${env}"
        },
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "id", "AttributeType": "S" },
          { "AttributeName": "recipientId", "AttributeType": "S" },
          { "AttributeName": "createdAt", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "id", "KeyType": "HASH" },
          { "AttributeName": "recipientId", "KeyType": "RANGE" }
        ],
        "GlobalSecondaryIndexes": [
          {
            "IndexName": "byRecipient",
            "KeySchema": [
              { "AttributeName": "recipientId", "KeyType": "HASH" },
              { "AttributeName": "createdAt", "KeyType": "RANGE" }
            ],
            "Projection": { "ProjectionType": "ALL" }
          }
        ]
      }
    },
    "UsersTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {
          "Fn::Sub": "BuzzerUsers-${AppSyncApiId}-${env}"
        },
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "id", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "id", "KeyType": "HASH" }
        ]
      }
    },
    "NotificationDLQ": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": {
          "Fn::Sub": "BuzzerNotificationDLQ-${AppSyncApiId}-${env}"
        },
        "MessageRetentionPeriod": 604800
      }
    },
    "NotificationQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": {
          "Fn::Sub": "BuzzerNotificationQueue-${AppSyncApiId}-${env}"
        },
        "VisibilityTimeout": 60,
        "MessageRetentionPeriod": 345600,
        "RedrivePolicy": {
          "deadLetterTargetArn": {
            "Fn::GetAtt": ["NotificationDLQ", "Arn"]
          },
          "maxReceiveCount": 3
        }
      }
    },
    "FollowsDataSourceRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "FollowsTableAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:PutItem",
                    "dynamodb:UpdateItem",
                    "dynamodb:GetItem",
                    "dynamodb:Query",
                    "dynamodb:ConditionCheckItem"
                  ],
                  "Resource": [
                    { "Fn::GetAtt": ["FollowsTable", "Arn"] },
                    {
                      "Fn::Sub": "${FollowsTable.Arn}/index/*"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "NotificationsDataSourceRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "NotificationsTableAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:PutItem",
                    "dynamodb:GetItem",
                    "dynamodb:Query"
                  ],
                  "Resource": [
                    { "Fn::GetAtt": ["NotificationsTable", "Arn"] },
                    {
                      "Fn::Sub": "${NotificationsTable.Arn}/index/*"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "UsersDataSourceRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "UsersTableAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:GetItem",
                    "dynamodb:PutItem",
                    "dynamodb:UpdateItem"
                  ],
                  "Resource": {
                    "Fn::GetAtt": ["UsersTable", "Arn"]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "SqsPublishRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "SqsPublishAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:SendMessage"
                  ],
                  "Resource": {
                    "Fn::GetAtt": ["NotificationQueue", "Arn"]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "FollowsTableDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerFollowsTableDS",
        "Type": "AMAZON_DYNAMODB",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["FollowsDataSourceRole", "Arn"]
        },
        "DynamoDBConfig": {
          "AwsRegion": {
            "Ref": "AWS::Region"
          },
          "TableName": {
            "Ref": "FollowsTable"
          }
        }
      }
    },
    "NotificationsTableDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerNotificationsTableDS",
        "Type": "AMAZON_DYNAMODB",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["NotificationsDataSourceRole", "Arn"]
        },
        "DynamoDBConfig": {
          "AwsRegion": {
            "Ref": "AWS::Region"
          },
          "TableName": {
            "Ref": "NotificationsTable"
          }
        }
      }
    },
    "UsersTableDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerUsersTableDS",
        "Type": "AMAZON_DYNAMODB",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["UsersDataSourceRole", "Arn"]
        },
        "DynamoDBConfig": {
          "AwsRegion": {
            "Ref": "AWS::Region"
          },
          "TableName": {
            "Ref": "UsersTable"
          }
        }
      }
    },
    "SqsHttpDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerSqsDS",
        "Type": "HTTP",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["SqsPublishRole", "Arn"]
        },
        "HttpConfig": {
          "Endpoint": {
            "Fn::Sub": "https://sqs.${AWS::Region}.amazonaws.com"
          },
          "AuthorizationConfig": {
            "AuthorizationType": "AWS_IAM",
            "AwsIamConfig": {
              "SigningRegion": {
                "Ref": "AWS::Region"
              },
              "SigningServiceName": "sqs"
            }
          }
        }
      }
    },
    "UpsertCallerProfileFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "upsertCallerProfile",
        "DataSourceName": { "Fn::GetAtt": ["UsersTableDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/User.upsertSelf.js"
        }
      }
    },
    "RequestFollowWriteFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "requestFollowWrite",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.requestFollow.js"
        }
      }
    },
    "RequestFollowPublishFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "requestFollowPublish",
        "DataSourceName": { "Fn::GetAtt": ["SqsHttpDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.requestFollow.SQS.js"
        }
      }
    },
    "AcceptFollowWriteFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "acceptFollowWrite",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.acceptFollowRequest.js"
        }
      }
    },
    "AcceptFollowPublishFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "acceptFollowPublish",
        "DataSourceName": { "Fn::GetAtt": ["SqsHttpDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.acceptFollowRequest.SQS.js"
        }
      }
    },
    "RequestFollowResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Mutation",
        "FieldName": "requestFollow",
        "Kind": "PIPELINE",
        "PipelineConfig": {
          "Functions": [
            { "Fn::GetAtt": ["UpsertCallerProfileFunction", "FunctionId"] },
            { "Fn::GetAtt": ["RequestFollowWriteFunction", "FunctionId"] },
            { "Fn::GetAtt": ["RequestFollowPublishFunction", "FunctionId"] }
          ]
        },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Pipeline.forward.js"
        }
      }
    },
    "AcceptFollowRequestResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Mutation",
        "FieldName": "acceptFollowRequest",
        "Kind": "PIPELINE",
        "PipelineConfig": {
          "Functions": [
            { "Fn::GetAtt": ["UpsertCallerProfileFunction", "FunctionId"] },
            { "Fn::GetAtt": ["AcceptFollowWriteFunction", "FunctionId"] },
            { "Fn::GetAtt": ["AcceptFollowPublishFunction", "FunctionId"] }
          ]
        },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Pipeline.forward.js"
        }
      }
    },
    "GetMyFollowersResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
