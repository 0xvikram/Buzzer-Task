{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Custom resources for the Buzzer social graph API.",
  "Parameters": {
    "AppSyncApiId": {
      "Type": "String"
    },
    "AppSyncApiName": {
      "Type": "String",
      "Default": "buzzertask"
    },
    "env": {
      "Type": "String",
      "Default": "NONE"
    },
    "S3DeploymentBucket": {
      "Type": "String"
    },
    "S3DeploymentRootKey": {
      "Type": "String"
    }
  },
  "Resources": {
    "BuzzerNoneDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerNoneDS",
        "Type": "NONE"
      }
    },
    "FollowsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {
          "Fn::Sub": "BuzzerFollows-${AppSyncApiId}-${env}"
        },
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "requesterId", "AttributeType": "S" },
          { "AttributeName": "targetId", "AttributeType": "S" },
          { "AttributeName": "status", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "requesterId", "KeyType": "HASH" },
          { "AttributeName": "targetId", "KeyType": "RANGE" }
        ],
        "GlobalSecondaryIndexes": [
          {
            "IndexName": "byTarget",
            "KeySchema": [
              { "AttributeName": "targetId", "KeyType": "HASH" },
              { "AttributeName": "status", "KeyType": "RANGE" }
            ],
            "Projection": { "ProjectionType": "ALL" }
          },
          {
            "IndexName": "byRequester",
            "KeySchema": [
              { "AttributeName": "requesterId", "KeyType": "HASH" },
              { "AttributeName": "status", "KeyType": "RANGE" }
            ],
            "Projection": { "ProjectionType": "ALL" }
          }
        ]
      }
    },
    "NotificationsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {
          "Fn::Sub": "BuzzerNotifications-${AppSyncApiId}-${env}"
        },
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "id", "AttributeType": "S" },
          { "AttributeName": "recipientId", "AttributeType": "S" },
          { "AttributeName": "createdAt", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "id", "KeyType": "HASH" },
          { "AttributeName": "recipientId", "KeyType": "RANGE" }
        ],
        "GlobalSecondaryIndexes": [
          {
            "IndexName": "byRecipient",
            "KeySchema": [
              { "AttributeName": "recipientId", "KeyType": "HASH" },
              { "AttributeName": "createdAt", "KeyType": "RANGE" }
            ],
            "Projection": { "ProjectionType": "ALL" }
          }
        ]
      }
    },
    "NotificationDLQ": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": {
          "Fn::Sub": "BuzzerNotificationDLQ-${AppSyncApiId}-${env}"
        },
        "MessageRetentionPeriod": 604800
      }
    },
    "NotificationQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": {
          "Fn::Sub": "BuzzerNotificationQueue-${AppSyncApiId}-${env}"
        },
        "VisibilityTimeout": 60,
        "MessageRetentionPeriod": 345600,
        "RedrivePolicy": {
          "deadLetterTargetArn": {
            "Fn::GetAtt": ["NotificationDLQ", "Arn"]
          },
          "maxReceiveCount": 3
        }
      }
    },
    "FollowsDataSourceRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "FollowsTableAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:PutItem",
                    "dynamodb:UpdateItem",
                    "dynamodb:GetItem",
                    "dynamodb:Query",
                    "dynamodb:ConditionCheckItem"
                  ],
                  "Resource": [
                    { "Fn::GetAtt": ["FollowsTable", "Arn"] },
                    {
                      "Fn::Sub": "${FollowsTable.Arn}/index/*"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "NotificationsDataSourceRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "NotificationsTableAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:PutItem",
                    "dynamodb:GetItem",
                    "dynamodb:Query"
                  ],
                  "Resource": [
                    { "Fn::GetAtt": ["NotificationsTable", "Arn"] },
                    {
                      "Fn::Sub": "${NotificationsTable.Arn}/index/*"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "UsersDataSourceRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "UsersTableAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:GetItem"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:aws:dynamodb:${AWS::Region}:${AWS::AccountId}:table/BuzzerUsers-${env}"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "SqsPublishRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "SqsPublishAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:SendMessage"
                  ],
                  "Resource": {
                    "Fn::GetAtt": ["NotificationQueue", "Arn"]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "FollowsTableDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerFollowsTableDS",
        "Type": "AMAZON_DYNAMODB",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["FollowsDataSourceRole", "Arn"]
        },
        "DynamoDBConfig": {
          "AwsRegion": {
            "Ref": "AWS::Region"
          },
          "TableName": {
            "Ref": "FollowsTable"
          }
        }
      }
    },
    "NotificationsTableDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerNotificationsTableDS",
        "Type": "AMAZON_DYNAMODB",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["NotificationsDataSourceRole", "Arn"]
        },
        "DynamoDBConfig": {
          "AwsRegion": {
            "Ref": "AWS::Region"
          },
          "TableName": {
            "Ref": "NotificationsTable"
          }
        }
      }
    },
    "UsersTableDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerUsersTableDS",
        "Type": "AMAZON_DYNAMODB",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["UsersDataSourceRole", "Arn"]
        },
        "DynamoDBConfig": {
          "AwsRegion": {
            "Ref": "AWS::Region"
          },
          "TableName": {
            "Fn::Sub": "BuzzerUsers-${env}"
          }
        }
      }
    },
    "SqsHttpDataSource": {
      "Type": "AWS::AppSync::DataSource",
      "Properties": {
        "ApiId": {
          "Ref": "AppSyncApiId"
        },
        "Name": "BuzzerSqsDS",
        "Type": "HTTP",
        "ServiceRoleArn": {
          "Fn::GetAtt": ["SqsPublishRole", "Arn"]
        },
        "HttpConfig": {
          "Endpoint": {
            "Ref": "NotificationQueue"
          },
          "AuthorizationConfig": {
            "AuthorizationType": "AWS_IAM",
            "AwsIamConfig": {
              "SigningRegion": {
                "Ref": "AWS::Region"
              },
              "SigningServiceName": "sqs"
            }
          }
        }
      }
    },
    "RequestFollowWriteFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "requestFollowWrite",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.requestFollow.js"
        }
      }
    },
    "RequestFollowPublishFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "requestFollowPublish",
        "DataSourceName": { "Fn::GetAtt": ["SqsHttpDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.requestFollow.SQS.js"
        }
      }
    },
    "AcceptFollowWriteFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "acceptFollowWrite",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.acceptFollowRequest.js"
        }
      }
    },
    "AcceptFollowPublishFunction": {
      "Type": "AWS::AppSync::FunctionConfiguration",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "Name": "acceptFollowPublish",
        "DataSourceName": { "Fn::GetAtt": ["SqsHttpDataSource", "Name"] },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.acceptFollowRequest.SQS.js"
        }
      }
    },
    "RequestFollowResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Mutation",
        "FieldName": "requestFollow",
        "Kind": "PIPELINE",
        "PipelineConfig": {
          "Functions": [
            { "Fn::GetAtt": ["RequestFollowWriteFunction", "FunctionId"] },
            { "Fn::GetAtt": ["RequestFollowPublishFunction", "FunctionId"] }
          ]
        },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Pipeline.forward.js"
        }
      }
    },
    "AcceptFollowRequestResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Mutation",
        "FieldName": "acceptFollowRequest",
        "Kind": "PIPELINE",
        "PipelineConfig": {
          "Functions": [
            { "Fn::GetAtt": ["AcceptFollowWriteFunction", "FunctionId"] },
            { "Fn::GetAtt": ["AcceptFollowPublishFunction", "FunctionId"] }
          ]
        },
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Pipeline.forward.js"
        }
      }
    },
    "GetMyFollowersResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Query",
        "FieldName": "getMyFollowers",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyFollowers.js"
        }
      }
    },
    "GetMyFollowingsResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Query",
        "FieldName": "getMyFollowings",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyFollowings.js"
        }
      }
    },
    "GetMyPendingRequestsResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Query",
        "FieldName": "getMyPendingFollowRequests",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyPendingFollowRequests.js"
        }
      }
    },
    "GetMyProfileResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Query",
        "FieldName": "getMyProfile",
        "DataSourceName": { "Fn::GetAtt": ["UsersTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyProfile.js"
        }
      }
    },
    "GetMyNotificationsResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Query",
        "FieldName": "getMyNotifications",
        "DataSourceName": { "Fn::GetAtt": ["NotificationsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyNotifications.js"
        }
      }
    },
    "CreateNotificationInternalResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Mutation",
        "FieldName": "createNotificationInternal",
        "DataSourceName": { "Fn::GetAtt": ["NotificationsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Mutation.createNotificationInternal.js"
        }
      }
    },
    "OnFollowAcceptedResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Subscription",
        "FieldName": "onFollowAccepted",
        "DataSourceName": { "Fn::GetAtt": ["BuzzerNoneDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Subscription.onFollowAccepted.js"
        }
      }
    },
    "OnNotificationResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Subscription",
        "FieldName": "onNotification",
        "DataSourceName": { "Fn::GetAtt": ["BuzzerNoneDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Subscription.onNotification.js"
        }
      }
    },
    "UserFollowEdgeUserResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "UserFollowEdge",
        "FieldName": "user",
        "DataSourceName": { "Fn::GetAtt": ["UsersTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/UserFollowEdge.user.js"
        }
      }
    },
    "NotificationProcessorRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ],
        "Policies": [
          {
            "PolicyName": "NotificationProcessorAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:ReceiveMessage",
                    "sqs:DeleteMessage",
                    "sqs:GetQueueAttributes"
                  ],
                  "Resource": {
                    "Fn::GetAtt": ["NotificationQueue", "Arn"]
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "appsync:GraphQL"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:aws:appsync:${AWS::Region}:${AWS::AccountId}:apis/${AppSyncApiId}/*"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "NotificationProcessorLambda": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "FunctionName": {
          "Fn::Sub": "buzzer-notification-processor-${AppSyncApiId}-${env}"
        },
        "Runtime": "nodejs20.x",
        "Role": {
          "Fn::GetAtt": ["NotificationProcessorRole", "Arn"]
        },
        "Handler": "src/index.handler",
        "Timeout": 30,
        "Code": {
          "S3Bucket": { "Ref": "S3DeploymentBucket" },
          "S3Key": {
            "Fn::Sub": "${S3DeploymentRootKey}/assets/notificationProcessor.zip"
          }
        },
        "Environment": {
          "Variables": {
            "AWS_REGION": {
              "Ref": "AWS::Region"
            },
            "APPSYNC_ENDPOINT": {
              "Fn::Sub": "https://${AppSyncApiId}.appsync-api.${AWS::Region}.amazonaws.com/graphql"
            }
          }
        }
      }
    },
    "NotificationProcessorEventSourceMapping": {
      "Type": "AWS::Lambda::EventSourceMapping",
      "Properties": {
        "BatchSize": 10,
        "Enabled": true,
        "EventSourceArn": {
          "Fn::GetAtt": ["NotificationQueue", "Arn"]
        },
        "FunctionName": {
          "Ref": "NotificationProcessorLambda"
        }
      }
    }
  },
  "Outputs": {
    "FollowsTableName": {
      "Value": { "Ref": "FollowsTable" }
    },
    "NotificationsTableName": {
      "Value": { "Ref": "NotificationsTable" }
    },
    "NotificationQueueUrl": {
      "Value": { "Ref": "NotificationQueue" }
    }
  }
}
