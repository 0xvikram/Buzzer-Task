        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Subscription.onFollowAccepted.js"
        }
      }
    },
    "OnNotificationResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Subscription",
        "FieldName": "onNotification",
        "DataSourceName": { "Fn::GetAtt": ["BuzzerNoneDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Subscription.onNotification.js"
        }
