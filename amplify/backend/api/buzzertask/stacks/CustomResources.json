        "TypeName": "Query",
        "FieldName": "getMyPendingFollowRequests",
        "DataSourceName": { "Fn::GetAtt": ["FollowsTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyPendingFollowRequests.js"
        }
      }
    },
    "GetMyProfileResolver": {
      "Type": "AWS::AppSync::Resolver",
      "Properties": {
        "ApiId": { "Ref": "AppSyncApiId" },
        "TypeName": "Query",
        "FieldName": "getMyProfile",
        "DataSourceName": { "Fn::GetAtt": ["UsersTableDataSource", "Name"] },
        "Kind": "UNIT",
        "Runtime": { "Name": "APPSYNC_JS", "RuntimeVersion": "1.0.0" },
        "CodeS3Location": {
          "Fn::Sub": "s3://${S3DeploymentBucket}/${S3DeploymentRootKey}/resolvers/Query.getMyProfile.js"
        }
      }
    },
    "GetMyNotificationsResolver": {
      "Type": "AWS::AppSync::Resolver",
